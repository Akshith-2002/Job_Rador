{
  "name": "job-scrapper",
  "version": "1.0.0",
  "description": "LinkedIn job scraper (via Apify) with resume-based fit scoring, Postgres + TypeORM storage, and a web dashboard.",
  "main": "src/server.ts",
  "scripts": {
    "scrape": "tsx src/scrape.ts",
    "ingest": "tsx src/ingest.ts",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "refresh": "npm run scrape && npm run ingest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@types/pdfkit": "^0.17.6",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
